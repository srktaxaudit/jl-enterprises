{
  "expo": {
    "name": "JL Store",
    "slug": "jl-store-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "jlstore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b2447"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jlenterprises.store"
    },
    "android": {
      "package": "com.jlenterprises.store",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b2447"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "apiBaseUrl": "https://jl-enterprises-api.onrender.com"
    }
  }
}
