# ─────────────────────────────────────────────────────────────────────────────
#  JL backend — environment variables (TEMPLATE)
#
#  Copy to .env for local use, or set these in the Render dashboard for the
#  deployed service. .env is gitignored; THIS file is tracked, so it must only
#  ever contain PLACEHOLDERS — never a real secret, key or password.
#
#  Local development needs NONE of these: application.yml ships working local
#  defaults (localhost DB, dev JWT secret). They matter for real deployments.
#
#  See DEPLOY.md for the full deployment walkthrough.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED IN PRODUCTION ──
# With SPRING_PROFILES_ACTIVE=prod the app REFUSES TO BOOT if any of the five
# below is missing or unsafe (StartupConfigValidator). The error names the
# variable to fix and never prints its value.

# Activates the production profile and its config checks.
SPRING_PROFILES_ACTIVE=prod

# JWT signing secret. Strong, random, at least 32 bytes. Must NOT be the
# development default. Render's blueprint generates this automatically.
#   generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# Database password (Supabase → Project Settings → Database).
# Must not be blank or the development default.
DB_PASSWORD=replace-with-your-database-password

# Initial SUPER_ADMIN password, used only when seeding a fresh database.
# At least 12 characters, unique, not a known/weak default. Change it after
# the first login.
APP_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-unique-password

# EXACT browser origins allowed to call this API, comma-separated.
# No wildcards ("*" is rejected), no localhost in production.
CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example

# Vercel preview origins. Keep "false" in production.
#
# Setting this to "true" adds the pattern https://*.vercel.app to the CORS
# allow-list — that matches EVERY site on vercel.app, not only ours, so any of
# them could call this API from a browser. Enable it only to test a preview
# build against this API, then set it straight back to "false". Each boot with
# it enabled logs a loud warning. Preferably promote the build to a real domain
# listed in CORS_ORIGINS instead.
APP_SECURITY_CORS_ALLOW_VERCEL_PREVIEWS=false

# ── Database connection ──
# Use the Supabase SESSION pooler (IPv4 + prepared statements); not the
# Transaction pooler on 6543.
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USER=postgres.<project-ref>
DB_POOL_MAX=5

# ── Redis / Key Value (OTP + verification tokens) ──
# Auto-wired by render.yaml from the jl-ecom-redis service.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email (SMTP) — required for OTP, email verification & password reset ──
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true
MAIL_FROM=no-reply@your-domain.example
# Where the password-reset email links (your storefront reset page).
PASSWORD_RESET_URL=https://your-domain.example/reset-password.html

# ── Supabase Storage — product image uploads (blank = uploads disabled) ──
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key — SERVER-SIDE ONLY, never expose to the browser.
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key
SUPABASE_BUCKET=product-images

# ── Razorpay online payments (blank = COD-only) ──
# Use test keys (rzp_test_...) before switching to live keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── WhatsApp Cloud API broadcast (blank = demo mode, nothing is sent) ──
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Schema management ──
# Entity-development mode. To productionise: freeze the schema into a Flyway
# migration, then set JPA_DDL_AUTO=validate and FLYWAY_ENABLED=true.
JPA_DDL_AUTO=update
FLYWAY_ENABLED=false

# ── API docs ──
# Disabled by default so the API surface is not public. Set true locally only.
SWAGGER_ENABLED=false
