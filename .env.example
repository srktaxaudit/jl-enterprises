# ── JL Enterprises store — environment ──────────────────────────────
# Copy this file to ".env.local" and fill in JL's OWN credentials.
# Keep these SEPARATE from any SRK project. Never commit .env.local.

# Supabase (create a NEW project for JL — not the SRK database)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-JL-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Site
NEXT_PUBLIC_SITE_URL=https://jlenterprises.in

# Razorpay (JL's OWN account — settles to JL's bank).
# From Razorpay Dashboard → Settings → API Keys. Use test keys first.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# WhatsApp Business Cloud API (JL's OWN Meta number).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TPL_ORDER=        # approved template name for order confirmation (optional)

# Admin token guarding the WhatsApp broadcast endpoint (set any strong secret)
ADMIN_API_TOKEN=

# NOTE: Until NEXT_PUBLIC_SUPABASE_URL is set, the app runs on built-in
# seed data so you can preview it immediately with `npm run dev`.
